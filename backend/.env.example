# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=Bayyn
APP_ENV=production       # development | production

# ── Security (REQUIRED in production) ────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
JWT_EXPIRE_MINUTES=10080   # 7 days

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://bayyn:bayyn@postgres:5432/bayyn
SYNC_DATABASE_URL=postgresql://bayyn:bayyn@postgres:5432/bayyn

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── CORS (comma-separated origins) ───────────────────────────────────────────
# CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# ── Temp storage ─────────────────────────────────────────────────────────────
TEMP_DIR=/tmp/bayyn

# ── Transcription limits ──────────────────────────────────────────────────────
MAX_VIDEO_DURATION_SECONDS=7200
CHUNK_THRESHOLD_SECONDS=600
CHUNK_DURATION_SECONDS=600
JOB_TIMEOUT_SECONDS=3600
MAX_TRANSCRIPT_CHARS=1000000
WHISPER_MODEL=large-v3
DEFAULT_LANGUAGE=en

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=10
MAX_ACTIVE_JOBS_PER_USER=5
MAX_DAILY_JOBS_PER_USER=20

# ── Optional: LLM summary ────────────────────────────────────────────────────
ENABLE_LLM_SUMMARY=false
# OPENAI_API_KEY=sk-...   # Required when ENABLE_LLM_SUMMARY=true
